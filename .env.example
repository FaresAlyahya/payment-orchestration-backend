# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — single URL (recommended for AWS App Runner / any cloud provider)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:your_password@payment-db.ch8oq6210xwm.eu-central-1.rds.amazonaws.com:5432/payment_orchestration

# Option B — individual variables (used when DATABASE_URL is not set)
DB_HOST=payment-db.ch8oq6210xwm.eu-central-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=payment_orchestration
DB_USER=postgres
DB_PASSWORD=your_password_here

# SSL for RDS:
#   true  = enforce SSL with certificate verification (most secure)
#   false = disable SSL (local/docker-compose only)
#   unset = SSL on in production with rejectUnauthorized:false (default)
DB_SSL=false

# Set to true only on first deploy to create tables, then remove
DB_SYNCHRONIZE=true

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# ── Moyasar PSP ───────────────────────────────────────────────────────────────
MOYASAR_API_KEY=your_moyasar_test_api_key
MOYASAR_API_URL=https://api.moyasar.com/v1
MOYASAR_WEBHOOK_SECRET=your_webhook_secret

# ── PayTabs PSP ───────────────────────────────────────────────────────────────
PAYTABS_SERVER_KEY=your_paytabs_server_key
PAYTABS_PROFILE_ID=your_profile_id
PAYTABS_API_URL=https://secure.paytabs.sa
# Where PayTabs POSTs the payment result after customer pays
PAYTABS_CALLBACK_URL=https://your-backend.com/api/v1/webhooks/paytabs
# Where PayTabs redirects the customer after payment (your frontend)
PAYTABS_RETURN_URL=https://your-frontend.com/payment-result

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis for distributed rate limiting across multiple instances (optional)
# Without this, rate limiting falls back to in-memory (single instance only)
REDIS_URL=redis://localhost:6379

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend dashboard URL
FRONTEND_URL=https://your-frontend-domain.com
